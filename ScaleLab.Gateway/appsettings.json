{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "web-api",
        "Match": { "Path": "{**catch-all}" },
        "Transforms": [{ "RequestHeaderOriginalHost": "true" }]
      }
    },
    "Clusters": {
      "web-api": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpClient": { "MaxConnectionsPerServer": 32 },
        "Destinations": {
          "api": { "Address": "http://web-api:8080" }
        }
      }
    }
  }
}
